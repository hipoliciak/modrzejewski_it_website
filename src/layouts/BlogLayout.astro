---
import Layout from './Layout.astro';
import { tagToSlug } from '../utils/tags';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  category: string;
  tags: string[];
  image?: string;
}

const { title, description, pubDate, updatedDate, author, category, tags, image } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const displayUpdatedDate = updatedDate ?? pubDate;
const formattedDisplayUpdatedDate = displayUpdatedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechnicalArticle',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://modrzejewski.it/',
  },
  datePublished: pubDate.toISOString(),
  dateModified: displayUpdatedDate.toISOString(),
  articleSection: category,
  keywords: tags.join(', '),
  mainEntityOfPage: Astro.url.href,
};
---

<Layout title={title} description={description} image={image} type="article" structuredData={articleSchema}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-10">
      <div class="mb-4">
        <span class="inline-block bg-brand-navy text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
          {category}
        </span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 dark:text-white leading-tight mb-6">
        {title}
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-6">{description}</p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400 border-t border-b border-gray-200 dark:border-gray-700 py-4">
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          {author}
        </span>
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Created: <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        </span>
        <span class="text-gray-400 dark:text-gray-500">
          Updated: <time datetime={displayUpdatedDate.toISOString()}>{formattedDisplayUpdatedDate}</time>
        </span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <a
              href={`/tags/${tagToSlug(tag)}`}
              class="text-xs font-medium bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-200 border border-slate-300/80 dark:border-slate-600 px-3 py-1 rounded-full hover:bg-brand-red hover:text-white dark:hover:bg-brand-red dark:hover:text-white transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg dark:prose-invert prose-headings:font-bold prose-a:text-brand-navy dark:prose-a:text-blue-400 prose-code:text-brand-navy dark:prose-code:text-blue-300 max-w-none">
      <slot />
    </div>
  </article>

  <!-- Mermaid.js support -->
  <script>
    import mermaid from 'mermaid';
    let isRendering = false;
    let hasQueuedRender = false;

    const getTheme = () => (
      document.documentElement.classList.contains('dark') ? 'dark' : 'default'
    );

    // Convert markdown fences (```mermaid) into Mermaid containers.
    const convertCodeFences = () => {
      const candidates = [
        ...document.querySelectorAll('pre[data-language="mermaid"]'),
        ...document.querySelectorAll('code.language-mermaid'),
      ];

      candidates.forEach((candidate) => {
        const preEl = candidate.tagName === 'PRE' ? candidate : candidate.closest('pre');
        if (!preEl) return;
        if (preEl.getAttribute('data-mermaid-converted') === 'true') return;

        const definition = preEl.textContent?.trim();
        if (!definition) return;

        const mermaidEl = document.createElement('div');
        mermaidEl.className = 'mermaid';
        mermaidEl.setAttribute('data-mermaid-definition', definition);
        mermaidEl.textContent = definition;
        preEl.setAttribute('data-mermaid-converted', 'true');
        preEl.replaceWith(mermaidEl);
      });
    };

    // Restore source text so Mermaid can re-render when the theme changes.
    const resetRenderedDiagrams = () => {
      document.querySelectorAll('.mermaid').forEach((mermaidEl) => {
        const definition = mermaidEl.getAttribute('data-mermaid-definition');
        if (!definition) return;
        mermaidEl.removeAttribute('data-processed');
        mermaidEl.innerHTML = '';
        mermaidEl.textContent = definition;
      });
    };

    const renderMermaid = async () => {
      convertCodeFences();
      const diagrams = document.querySelectorAll('.mermaid');
      if (diagrams.length === 0) return;

      mermaid.initialize({
        startOnLoad: false,
        theme: getTheme(),
        securityLevel: 'loose',
      });
      await mermaid.run({ querySelector: '.mermaid' });
    };

    const initMermaid = async () => {
      if (isRendering) {
        hasQueuedRender = true;
        return;
      }

      isRendering = true;
      try {
        await renderMermaid();
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        const isKnownTransientError = message.includes('Could not find a suitable point for the given distance');
        if (!isKnownTransientError) {
          console.warn('Mermaid render warning:', error);
        }
      } finally {
        isRendering = false;
        if (hasQueuedRender) {
          hasQueuedRender = false;
          void initMermaid();
        }
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMermaid, { once: true });
    } else {
      void initMermaid();
    }

    document.addEventListener('astro:page-load', () => {
      void initMermaid();
    });

    const observer = new MutationObserver(() => {
      resetRenderedDiagrams();
      void initMermaid();
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });
  </script>
</Layout>
