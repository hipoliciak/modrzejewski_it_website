---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = 'Salesforce B2C Solution Architect portfolio and blog by Dominik Modrzejewski.',
  image,
  type,
  structuredData,
} = Astro.props;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Dominik Modrzejewski',
  url: 'https://modrzejewski.it/',
  jobTitle: 'Salesforce Solution Architect',
  sameAs: ['https://modrzejewski.it/'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Modrzejewski.IT',
  url: 'https://modrzejewski.it/',
  inLanguage: 'en',
};

const inputSchemas = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : [];

const allStructuredData = [personSchema, websiteSchema, ...inputSchemas];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      structuredData={allStructuredData}
    />
    <script is:inline>
      // Dark mode initialization - must run before page renders to avoid flash
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body id="page-top" style="--trailhead-icon-scale: 160% 160%;" class="bg-white dark:bg-brand-darkbg text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300 min-h-screen flex flex-col">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
