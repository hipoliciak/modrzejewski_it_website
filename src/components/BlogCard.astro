---
import { tagToSlug } from '../utils/tags';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  slug: string;
}

const { title, description, category, tags, slug } = Astro.props;
---

<article class="group bg-slate-50 dark:bg-slate-800/70 rounded-xl border border-slate-300 dark:border-slate-700 p-6 shadow-sm hover:shadow-lg hover:border-brand-navy dark:hover:border-blue-500 transition-all duration-300 hover:-translate-y-1">
  <a href={`/blog/${slug}`} class="block rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-navy dark:focus-visible:ring-blue-400">
    <div class="mb-3">
      <span class="inline-block bg-brand-navy/10 dark:bg-blue-500/20 text-brand-navy dark:text-blue-400 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
        {category}
      </span>
    </div>

    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2 group-hover:text-brand-navy dark:group-hover:text-blue-400 transition-colors leading-snug">
      {title}
    </h3>

    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-4">
      {description}
    </p>
  </a>

  <a
    href={`/blog/${slug}`}
    class="inline-flex items-center gap-2 bg-blue-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-brand-red dark:hover:bg-brand-red transition-colors mb-4"
  >
    Read more
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>

  <div class="flex flex-wrap gap-2">
    {tags.slice(0, 3).map((tag) => (
      <a
        href={`/tags/${tagToSlug(tag)}`}
        class="text-xs font-medium bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-200 border border-slate-300/80 dark:border-slate-600 px-2.5 py-1 rounded-md hover:bg-brand-red hover:text-white dark:hover:bg-brand-red dark:hover:text-white transition-colors"
      >
        {tag}
      </a>
    ))}
  </div>
</article>
