---
const formSubmitToken = '5cf95266933e1b198dc297aca263db44';
---

<div id="contact-form-wrapper" class="w-full">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Contact Me</h2>

  <form
    id="contact-form"
    class="space-y-6"
    method="POST"
    action={`https://formsubmit.co/${formSubmitToken}`}
    novalidate
  >
    <input type="hidden" name="_subject" value="New website contact message" />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_next" value="https://modrzejewski.it/contact?sent=1" />
    <input type="hidden" id="js-check" name="_js_check" value="0" />
    <input type="hidden" id="form-started-at" name="_form_started_at" value="" />
    <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />
    <input
      type="text"
      id="company-name"
      name="company_name"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      class="absolute -left-[9999px] opacity-0 pointer-events-none"
    />

    <div>
      <label for="name" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
        Full Name <span class="text-brand-red">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Jane Smith"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-navy dark:focus:ring-blue-500 focus:border-transparent transition-colors duration-200"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
        Email Address <span class="text-brand-red">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="jane@company.com"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-navy dark:focus:ring-blue-500 focus:border-transparent transition-colors duration-200"
      />
    </div>

    <div>
      <label for="subject" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
        Subject
      </label>
      <input
        type="text"
        id="subject"
        name="subject"
        placeholder="Salesforce architecture consultation"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-navy dark:focus:ring-blue-500 focus:border-transparent transition-colors duration-200"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
        Message <span class="text-brand-red">*</span>
      </label>
      <textarea
        id="message"
        name="message"
        required
        rows="6"
        placeholder="Tell me about your project or question..."
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-navy dark:focus:ring-blue-500 focus:border-transparent transition-colors duration-200 resize-vertical"
      ></textarea>
    </div>

    <div>
      <label for="privacy-consent" class="flex items-start gap-3 text-sm text-gray-700 dark:text-gray-300">
        <input
          id="privacy-consent"
          name="privacy_consent"
          type="checkbox"
          value="accepted"
          required
          class="mt-0.5 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800"
        />
        <span>
          I have read and accept the
          <a href="/privacy-policy" target="_blank" rel="noopener noreferrer" class="font-medium text-brand-navy dark:text-blue-400 hover:underline">
            Privacy Policy
          </a>
          <span class="text-brand-red">*</span>
        </span>
      </label>
    </div>

    <button
      type="submit"
      id="contact-submit"
      class="w-full bg-blue-600 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-200 shadow-md hover:bg-brand-red dark:hover:bg-brand-red hover:shadow-lg hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-brand-darkbg"
    >
      Send Message
    </button>
  </form>

  <div id="form-error" class="hidden mt-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-red-700 dark:text-red-300 text-sm">
    Please wait a few seconds and retry. If this persists, contact me through LinkedIn.
  </div>

  <div id="form-success" class="hidden mt-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-700 dark:text-green-300 text-sm">
    Thank you for your message! I'll get back to you soon.
  </div>
</div>

<script>
  const COOLDOWN_MS = 30000;
  const LAST_SUBMIT_KEY = 'contactLastSubmitAt';
  const params = new URLSearchParams(window.location.search);
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('contact-submit');
  const startedAtInput = document.getElementById('form-started-at');
  const jsCheckInput = document.getElementById('js-check');
  const companyNameInput = document.getElementById('company-name');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  if (startedAtInput) {
    startedAtInput.value = String(Date.now());
  }

  if (jsCheckInput) {
    jsCheckInput.value = '1';
  }

  if (params.get('sent') === '1') {
    localStorage.setItem(LAST_SUBMIT_KEY, String(Date.now()));
    form?.classList.add('hidden');
    successMsg?.classList.remove('hidden');
    window.history.replaceState({}, '', window.location.pathname);
  }

  const setLoading = (isLoading) => {
    if (!submitBtn) return;
    submitBtn.toggleAttribute('disabled', isLoading);
    submitBtn.classList.toggle('opacity-70', isLoading);
    submitBtn.classList.toggle('cursor-not-allowed', isLoading);
    submitBtn.classList.toggle('hover:-translate-y-0.5', !isLoading);
    submitBtn.innerHTML = isLoading
      ? 'Sending...'
      : 'Send Message';
  };

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const startedAt = Number.parseInt(startedAtInput?.value || '0', 10);
    const elapsed = Date.now() - startedAt;

    if (jsCheckInput?.value !== '1') {
      if (errorMsg) {
        errorMsg.textContent = 'Form validation failed. Please refresh the page and try again.';
        errorMsg.classList.remove('hidden');
      }
      return;
    }

    if ((companyNameInput instanceof HTMLInputElement) && companyNameInput.value.trim()) {
      if (errorMsg) {
        errorMsg.textContent = 'Form validation failed. Please refresh the page and try again.';
        errorMsg.classList.remove('hidden');
      }
      return;
    }

    if (!startedAt || elapsed < 3500) {
      if (errorMsg) {
        errorMsg.textContent = 'Please wait a few seconds before sending the form.';
        errorMsg.classList.remove('hidden');
      }
      return;
    }

    const lastSubmitAt = Number.parseInt(localStorage.getItem(LAST_SUBMIT_KEY) || '0', 10);
    const cooldownLeft = COOLDOWN_MS - (Date.now() - lastSubmitAt);

    if (lastSubmitAt && cooldownLeft > 0) {
      const secondsLeft = Math.ceil(cooldownLeft / 1000);
      if (errorMsg) {
        errorMsg.textContent = `Please wait ${secondsLeft}s before sending another message.`;
        errorMsg.classList.remove('hidden');
      }
      return;
    }

    setLoading(true);
    form.submit();
  });
</script>
