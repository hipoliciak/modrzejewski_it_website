---
import { tagToSlug } from '../utils/tags';

interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  demo?: string;
  slug: string;
}

const { title, description, tags, github, demo, slug } = Astro.props;
const projectUrl = `/projects/${slug}`;
---

<article class="group bg-white dark:bg-brand-darkcard rounded-xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-lg hover:border-brand-navy dark:hover:border-blue-500 transition-all duration-300 hover:-translate-y-1">
  <div class="flex items-start justify-between mb-4">
    <div class="p-2 bg-brand-navy/10 dark:bg-blue-500/10 rounded-lg">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-navy dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
    </div>
    <div class="flex gap-2">
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer" aria-label="GitHub repository"
          class="text-gray-400 hover:text-brand-navy dark:hover:text-white transition-colors duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" rel="noopener noreferrer" aria-label="Live demo"
          class="text-gray-400 hover:text-brand-navy dark:hover:text-white transition-colors duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <a
    href={projectUrl}
    class="block rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-navy dark:focus-visible:ring-blue-400"
    aria-label={`View details for ${title}`}
  >
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2 group-hover:text-brand-navy dark:group-hover:text-blue-400 transition-colors">
      {title}
    </h3>
    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-4">{description}</p>
  </a>

  <a
    href={projectUrl}
    class="inline-flex items-center gap-2 bg-brand-navy dark:bg-blue-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-brand-red dark:hover:bg-brand-red transition-colors mb-4"
    aria-label={`View details for ${title}`}
  >
    View details
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>

  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <a
        href={`/tags/${tagToSlug(tag)}`}
        class="text-xs font-medium bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-200 border border-slate-300/80 dark:border-slate-600 px-2.5 py-1 rounded-md hover:bg-brand-navy hover:text-white dark:hover:bg-blue-600 transition-colors"
      >
        {tag}
      </a>
    ))}
  </div>
</article>
