---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/images/Dominik_Modrzejewski.jpg';
---

<section class="relative overflow-hidden bg-[#060914] text-white">
  <div class="pointer-events-none absolute inset-0 opacity-35" style="background-image: linear-gradient(rgba(0, 255, 200, 0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 255, 200, 0.08) 1px, transparent 1px); background-size: 28px 28px;"></div>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(0,255,240,0.22),transparent_45%),radial-gradient(circle_at_80%_10%,rgba(255,80,140,0.16),transparent_40%),radial-gradient(circle_at_60%_80%,rgba(86,140,255,0.2),transparent_50%)]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-[4.5rem] pb-10 md:pt-[5.5rem] md:pb-14">
    <div class="grid grid-cols-1 min-[800px]:grid-cols-12 gap-10 min-[800px]:gap-12 items-center min-[800px]:items-start">
      <div id="hero-copy-block" class="max-w-4xl min-[800px]:col-span-7 min-[800px]:max-w-3xl">
        <h1 class="text-[clamp(2.25rem,7vw,4.5rem)] font-extrabold leading-tight mb-6">
          Let's talk...
          <span class="block text-brand-red mt-2 hero-rotating-text hero-rotating-visible" id="hero-rotating-text">
            Data 360
          </span>
        </h1>

        <p class="text-[clamp(0.88rem,1.25vw,1.05rem)] text-white max-w-full min-[800px]:max-w-[34ch] lg:max-w-2xl mb-10 leading-relaxed">
          I'm Salesforce B2C Architect, ex-PR Director, and tech explorer. Specialized in enterprise system architecture, customer management, and marketing automation. Exploring the intersection of data, CRM, and business strategy.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2.5 text-sm sm:text-base rounded-lg font-semibold hover:bg-brand-red dark:hover:bg-brand-red transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 dark:focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-[#060914]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            Read Blog
          </a>

          <a
            href="/about-me"
            class="inline-flex items-center gap-2 bg-white text-blue-600 px-4 py-2.5 text-sm sm:text-base rounded-lg font-semibold border border-blue-200 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[#060914]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A9 9 0 1118.364 4.56M15 11a3 3 0 11-6 0 3 3 0 016 0zm-7 8a7 7 0 0114 0" />
            </svg>
            About Me
          </a>
        </div>
      </div>

      <div class="hidden min-[800px]:block min-[800px]:col-span-5 min-[800px]:justify-self-end">
        <div id="hero-photo-wrap" class="relative w-fit min-[800px]:ml-auto min-[800px]:mr-0">
          <div class="absolute -inset-1 rounded-3xl bg-gradient-to-br from-cyan-300/45 via-blue-400/35 to-fuchsia-500/30 blur-lg"></div>
          <div class="relative rounded-3xl overflow-hidden border border-cyan-200/30 bg-slate-900/60 shadow-2xl backdrop-blur-sm aspect-square h-full">
            <Image
              src={profilePhoto}
              alt="Portrait of Dominik Modrzejewski"
              format="webp"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const rotatingTerms = ['Data 360', 'Architecture', 'Salesforce', 'Marketing', 'Strategy'];
  const rotatingEl = document.getElementById('hero-rotating-text');
  const heroCopyBlock = document.getElementById('hero-copy-block');
  const heroPhotoWrap = document.getElementById('hero-photo-wrap');

  const syncHeroPhotoHeight = () => {
    if (!heroCopyBlock || !heroPhotoWrap) return;

    if (!window.matchMedia('(min-width: 800px)').matches) {
      heroPhotoWrap.style.removeProperty('height');
      return;
    }

    const copyHeight = Math.ceil(heroCopyBlock.getBoundingClientRect().height);
    heroPhotoWrap.style.height = `${copyHeight}px`;
  };

  if (rotatingEl) {
    let i = 0;
    setInterval(() => {
      i = (i + 1) % rotatingTerms.length;
      rotatingEl.classList.remove('hero-rotating-visible');

      setTimeout(() => {
        rotatingEl.textContent = rotatingTerms[i];
        rotatingEl.classList.add('hero-rotating-visible');
      }, 180);
    }, 2200);
  }

  syncHeroPhotoHeight();
  window.addEventListener('resize', syncHeroPhotoHeight, { passive: true });

  if (heroCopyBlock && 'ResizeObserver' in window) {
    const heroResizeObserver = new ResizeObserver(syncHeroPhotoHeight);
    heroResizeObserver.observe(heroCopyBlock);
  }
</script>

<style>
  .hero-rotating-text {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .hero-rotating-text:not(.hero-rotating-visible) {
    opacity: 0;
    transform: translateY(6px);
  }

  .hero-rotating-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<section class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white border-y border-slate-200 dark:border-slate-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-7">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-4 justify-items-center">
      {[
        { value: '15+', label: 'Years Experience' },
        { value: '14+', label: 'Certifications' },
        { value: '60M+', label: 'Customers Served' },
        { value: '∞', label: 'Learning' },
      ].map(({ value, label }) => (
        <div class="w-full text-center">
          <div class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white">{value}</div>
          <div class="text-xs sm:text-sm text-slate-600 dark:text-blue-200/90 mt-1 uppercase tracking-wide">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
