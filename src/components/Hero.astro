---
const profilePhoto = '/images/Dominik_Modrzejewski.svg';
---

<section class="relative overflow-hidden bg-gradient-to-br from-brand-navy via-blue-900 to-slate-900 text-white">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-start lg:items-end">
      <div class="lg:col-span-7 max-w-3xl">
      <div class="flex items-center gap-2 mb-6">
        <div class="h-1 w-12 bg-brand-red rounded-full"></div>
        <span class="text-blue-300 font-medium text-sm uppercase tracking-wider">Portfolio</span>
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold leading-tight mb-6">
        Dominik<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-cyan-300">Modrzejewski</span>
      </h1>

      <p class="text-xl sm:text-2xl font-light text-blue-100 mb-4">
        Salesforce B2C Solution Architect
      </p>

      <p class="text-base sm:text-lg text-blue-200/80 max-w-2xl mb-10 leading-relaxed">
        Salesforce-certified architect with 15+ years of experience leading MarTech and digital
        transformation across fintech, gaming, and e-commerce. I design scalable customer data and
        activation architectures across Data 360, Marketing Cloud, and Salesforce CRM.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/cv"
          class="inline-flex items-center gap-2 bg-white text-brand-navy px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          View CV
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 bg-transparent border-2 border-white/50 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 hover:border-white transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          Read Blog
        </a>
      </div>
      </div>

      <div class="lg:col-span-5 w-full">
        <div class="relative mx-auto lg:ml-auto w-full max-w-xs sm:max-w-sm lg:max-w-md">
          <div class="absolute -inset-1 rounded-3xl bg-gradient-to-br from-cyan-300/40 via-blue-400/30 to-brand-red/40 blur-lg"></div>
          <div class="relative rounded-3xl overflow-hidden border border-white/20 bg-slate-800/40 shadow-2xl backdrop-blur-sm aspect-square">
            <img
              src={profilePhoto}
              alt="Portrait of Dominik Modrzejewski"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white border-y border-slate-200 dark:border-slate-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-7">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-4 justify-items-center">
      {[
        { value: '15+', label: 'Years Experience' },
        { value: '14+', label: 'Certifications' },
        { value: '60M', label: 'Unified Profiles' },
        { value: '10M+', label: 'Users Supported' },
      ].map(({ value, label }) => (
        <div class="w-full text-center">
          <div class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white">{value}</div>
          <div class="text-xs sm:text-sm text-slate-600 dark:text-blue-200/90 mt-1 uppercase tracking-wide">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
