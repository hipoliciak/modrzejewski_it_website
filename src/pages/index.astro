---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const showProjectArrows = featuredProjects.length > 3;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
const featuredPosts = allPosts
  .filter((p) => p.data.featured)
  .sort((a, b) => {
    const orderA = a.data.featuredOrder ?? Number.MAX_SAFE_INTEGER;
    const orderB = b.data.featuredOrder ?? Number.MAX_SAFE_INTEGER;
    if (orderA !== orderB) return orderA - orderB;
    return b.data.pubDate.getTime() - a.data.pubDate.getTime();
  })
  .slice(0, 3);
const homepagePosts = featuredPosts.length > 0 ? featuredPosts : latestPosts;
const showArticleArrows = homepagePosts.length > 3;

const projectTileWidthClass = 'w-[88%] sm:w-[62%] lg:w-[calc(33.333%-0.67rem)]';
const projectsTrackClass = showProjectArrows
  ? 'flex gap-4 overflow-x-auto pb-1 snap-x snap-mandatory scroll-smooth [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden'
  : 'flex gap-4 overflow-x-auto pb-1 snap-x snap-mandatory scroll-smooth [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden lg:overflow-visible lg:snap-none lg:justify-between';
const articleTileWidthClass = 'w-[88%] sm:w-[62%] lg:w-[calc(33.333%-0.67rem)]';
const articlesTrackClass = showArticleArrows
  ? 'flex gap-4 overflow-x-auto pb-1 snap-x snap-mandatory scroll-smooth [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden'
  : 'flex gap-4 overflow-x-auto pb-1 snap-x snap-mandatory scroll-smooth [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden lg:overflow-visible lg:snap-none lg:justify-between';
---

<Layout
  title="Home"
  description="Salesforce B2C Solution Architect portfolio and blog by Dominik Modrzejewski."
>
  <Hero />

  <!-- Delivered Projects -->
  <section id="featured-projects" class="relative overflow-hidden pt-14 pb-12 bg-brand-lightgray dark:bg-gray-900">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-0">
      <div class="absolute -top-24 -left-16 h-72 w-72 rounded-full bg-cyan-300/20 blur-3xl dark:bg-cyan-400/10"></div>
      <div class="absolute top-20 -right-16 h-80 w-80 rounded-full bg-amber-200/35 blur-3xl dark:bg-amber-300/10"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <div class="h-1 w-8 bg-brand-red rounded-full"></div>
            <span class="text-brand-gray dark:text-gray-400 text-sm font-medium uppercase tracking-wider">Work</span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white">
            Delivered Projects
          </h2>
        </div>
      </div>

      <div class="relative">
        {showProjectArrows && (
          <button
            type="button"
            id="projects-prev"
            aria-label="Previous project"
            class="hidden lg:flex absolute left-0 top-1/2 -translate-y-1/2 -translate-x-5 z-10 p-2 rounded-full border border-gray-300 dark:border-gray-700 bg-white/95 dark:bg-gray-900/95 text-gray-600 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 transition-colors shadow disabled:hidden"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
        )}

        <div
          id="projects-carousel"
          class={projectsTrackClass}
        >
          {featuredProjects.map((project) => (
            <div class:list={['snap-start shrink-0', projectTileWidthClass]}>
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                github={project.data.github}
                demo={project.data.demo}
                image={project.data.image}
                imageAlt={project.data.imageAlt}
                slug={project.id.replace(/\.(md|mdx)$/, '')}
              />
            </div>
          ))}
        </div>

        {showProjectArrows && (
          <button
            type="button"
            id="projects-next"
            aria-label="Next project"
            class="hidden lg:flex absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 z-10 p-2 rounded-full border border-gray-300 dark:border-gray-700 bg-white/95 dark:bg-gray-900/95 text-gray-600 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 transition-colors shadow disabled:hidden"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        )}
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="relative overflow-hidden pt-10 pb-14 bg-white dark:bg-brand-darkbg border-t-2 border-gray-200 dark:border-gray-700">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-0">
      <div class="absolute -bottom-20 -left-10 h-72 w-72 rounded-full bg-emerald-200/35 blur-3xl dark:bg-emerald-400/10"></div>
      <div class="absolute top-8 right-0 h-72 w-72 rounded-full bg-orange-200/30 blur-3xl dark:bg-orange-300/10"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <div class="h-1 w-8 bg-brand-red rounded-full"></div>
            <span class="text-brand-gray dark:text-gray-400 text-sm font-medium uppercase tracking-wider">Insights</span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white">
            Featured Articles
          </h2>
        </div>
      </div>

      <div class="relative">
        {showArticleArrows && (
          <button
            type="button"
            id="articles-prev"
            aria-label="Previous article"
            class="hidden lg:flex absolute left-0 top-1/2 -translate-y-1/2 -translate-x-5 z-10 p-2 rounded-full border border-gray-300 dark:border-gray-700 bg-white/95 dark:bg-gray-900/95 text-gray-600 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 transition-colors shadow disabled:hidden"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
        )}

        <div id="articles-carousel" class={articlesTrackClass}>
          {homepagePosts.map((post) => (
            <div class:list={['snap-start shrink-0', articleTileWidthClass]}>
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                category={post.data.category}
                tags={post.data.tags}
                image={post.data.image}
                imageAlt={post.data.imageAlt}
                slug={post.id.replace(/\.(md|mdx)$/, '')}
              />
            </div>
          ))}
        </div>

        {showArticleArrows && (
          <button
            type="button"
            id="articles-next"
            aria-label="Next article"
            class="hidden lg:flex absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 z-10 p-2 rounded-full border border-gray-300 dark:border-gray-700 bg-white/95 dark:bg-gray-900/95 text-gray-600 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 transition-colors shadow disabled:hidden"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        )}
      </div>
    </div>
  </section>

  <script>
    const carousel = document.getElementById('projects-carousel');
    const prevBtn = document.getElementById('projects-prev');
    const nextBtn = document.getElementById('projects-next');

    let cardStep = 360;

    const setupCarousel = () => {
      if (!carousel) return;
      const cards = [...carousel.querySelectorAll(':scope > .snap-start')];
      const firstCard = cards[0];
      if (!firstCard) return;

      const cardRect = firstCard.getBoundingClientRect();
      const style = window.getComputedStyle(carousel);
      const gap = Number.parseFloat(style.columnGap || style.gap || '16') || 16;

      cardStep = cardRect.width + gap;
    };

    const getScrollStep = () => {
      if (!carousel) return 360;
      return cardStep;
    };

    const updateButtonStates = () => {
      if (!carousel) return;

      const maxScrollLeft = Math.max(0, carousel.scrollWidth - carousel.clientWidth);
      const atStart = carousel.scrollLeft <= 2;
      const atEnd = carousel.scrollLeft >= maxScrollLeft - 2;

      if (prevBtn instanceof HTMLButtonElement) {
        prevBtn.disabled = atStart;
      }

      if (nextBtn instanceof HTMLButtonElement) {
        nextBtn.disabled = atEnd;
      }
    };

    setupCarousel();
    updateButtonStates();

    window.addEventListener('resize', () => {
      setupCarousel();
      updateButtonStates();
    });

    carousel?.addEventListener('scroll', updateButtonStates, { passive: true });

    prevBtn?.addEventListener('click', () => {
      carousel?.scrollBy({ left: -getScrollStep(), behavior: 'smooth' });
    });

    nextBtn?.addEventListener('click', () => {
      carousel?.scrollBy({ left: getScrollStep(), behavior: 'smooth' });
    });

    const articlesCarousel = document.getElementById('articles-carousel');
    const articlesPrevBtn = document.getElementById('articles-prev');
    const articlesNextBtn = document.getElementById('articles-next');

    let articleCardStep = 360;

    const setupArticlesCarousel = () => {
      if (!articlesCarousel) return;
      const cards = [...articlesCarousel.querySelectorAll(':scope > .snap-start')];
      const firstCard = cards[0];
      if (!firstCard) return;

      const cardRect = firstCard.getBoundingClientRect();
      const style = window.getComputedStyle(articlesCarousel);
      const gap = Number.parseFloat(style.columnGap || style.gap || '16') || 16;
      articleCardStep = cardRect.width + gap;
    };

    const getArticlesScrollStep = () => {
      if (!articlesCarousel) return 360;
      return articleCardStep;
    };

    const updateArticlesButtonStates = () => {
      if (!articlesCarousel) return;

      const maxScrollLeft = Math.max(0, articlesCarousel.scrollWidth - articlesCarousel.clientWidth);
      const atStart = articlesCarousel.scrollLeft <= 2;
      const atEnd = articlesCarousel.scrollLeft >= maxScrollLeft - 2;

      if (articlesPrevBtn instanceof HTMLButtonElement) {
        articlesPrevBtn.disabled = atStart;
      }

      if (articlesNextBtn instanceof HTMLButtonElement) {
        articlesNextBtn.disabled = atEnd;
      }
    };

    setupArticlesCarousel();
    updateArticlesButtonStates();

    articlesCarousel?.addEventListener('scroll', updateArticlesButtonStates, { passive: true });

    articlesPrevBtn?.addEventListener('click', () => {
      articlesCarousel?.scrollBy({ left: -getArticlesScrollStep(), behavior: 'smooth' });
    });

    articlesNextBtn?.addEventListener('click', () => {
      articlesCarousel?.scrollBy({ left: getArticlesScrollStep(), behavior: 'smooth' });
    });

    window.addEventListener('resize', () => {
      setupArticlesCarousel();
      updateArticlesButtonStates();
    });
  </script>
</Layout>
