---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);
const totalProjects = sortedProjects.length;
const generatedAt = new Date();
const generatedAtIso = generatedAt.toISOString();
const generatedAtLabel = generatedAt.toLocaleString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZoneName: 'short',
});
---

<Layout title="Projects Index" description="Machine-readable project index for language models and automated crawlers.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-labelledby="llm-project-index-heading">
    <h1 id="llm-project-index-heading" class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-4">
      Projects Index
    </h1>
    <p class="text-gray-600 dark:text-gray-300 mb-8">
      This page is optimized for machine-readable crawling and provides direct links to all project case studies.
    </p>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      Project case studies indexed: {totalProjects}
    </p>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      Last generated: <time datetime={generatedAtIso}>{generatedAtLabel}</time>
    </p>

    <ol class="space-y-4">
      {sortedProjects.map((project) => {
        const slug = project.id.replace(/\.(md|mdx)$/, '');
        return (
          <li class="border-b border-slate-200 dark:border-slate-700 pb-4">
            <a href={`/projects/${slug}`} class="font-semibold text-brand-navy dark:text-blue-400 underline">
              {project.data.title}
            </a>
            <p class="text-sm text-gray-600 dark:text-gray-300 mt-1">{project.data.description}</p>
          </li>
        );
      })}
    </ol>
  </section>
</Layout>
