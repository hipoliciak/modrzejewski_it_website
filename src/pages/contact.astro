---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Contact" description="Let's talk about Salesforce B2C architecture, MarTech, and enterprise customer data platforms.">
  <!-- Header -->
  <div class="bg-gradient-to-br from-brand-navy to-blue-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-3">
        <div class="h-1 w-8 bg-brand-red rounded-full"></div>
        <span class="text-blue-300 text-sm font-medium uppercase tracking-wider">Contact</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Let's Talk</h1>
      <p class="text-blue-200 text-lg max-w-2xl">
        I'm available for architecture consulting, advisory work, and speaking engagements focused on Salesforce B2C, MarTech, and enterprise customer data platforms.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
      <div class="lg:col-span-7">
        <ContactForm />
      </div>

      <div class="relative lg:col-span-5 max-w-lg lg:max-w-md w-full mx-auto lg:mx-0 lg:ml-auto">
        <div class="absolute -inset-2 rounded-3xl bg-gradient-to-br from-cyan-200/40 via-blue-300/30 to-brand-red/30 blur-xl dark:from-cyan-400/10 dark:via-blue-400/10 dark:to-brand-red/20"></div>
        <div class="relative rounded-3xl overflow-hidden border border-gray-200 dark:border-gray-700 shadow-xl bg-white dark:bg-slate-900">
          <img
            src="/images/Dominik_Einstein.jpg"
            alt="Dominik Modrzejewski portrait"
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</Layout>
