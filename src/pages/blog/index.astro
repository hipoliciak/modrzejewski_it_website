---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categories = ['All', ...new Set(sortedPosts.map((p) => p.data.category))];
---

<Layout title="Blog" description="Articles on Salesforce architecture, development best practices, and enterprise integration patterns.">
  <!-- Page Header -->
  <div class="bg-gradient-to-br from-brand-navy to-blue-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-3">
        <div class="h-1 w-8 bg-brand-red rounded-full"></div>
        <span class="text-blue-300 text-sm font-medium uppercase tracking-wider">Knowledge Base</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Blog</h1>
      <p class="text-blue-200 text-lg max-w-2xl">
        Insights on Salesforce architecture, integration patterns, and enterprise CRM best practices.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-10" id="category-filters">
      {categories.map((cat) => (
        <button
          data-category={cat}
          class:list={[
            'px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 category-btn',
            cat === 'All'
              ? 'bg-brand-navy text-white'
              : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-brand-navy hover:text-white',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
      {sortedPosts.map((post) => (
        <div data-category={post.data.category} class="post-item">
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            slug={post.slug}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-posts" class="hidden text-center py-16 text-gray-500 dark:text-gray-400">
      No posts found in this category.
    </div>
  </div>
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const postItems = document.querySelectorAll<HTMLElement>('.post-item');
  const noPosts = document.getElementById('no-posts');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category || 'All';

      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove('bg-brand-navy', 'text-white');
        b.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-300');
      });
      btn.classList.add('bg-brand-navy', 'text-white');
      btn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-300');

      // Filter posts
      let visibleCount = 0;
      postItems.forEach((item) => {
        const show = category === 'All' || item.dataset.category === category;
        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      if (noPosts) {
        noPosts.classList.toggle('hidden', visibleCount > 0);
      }
    });
  });
</script>
