---
import Layout from '../layouts/Layout.astro';
import cvData from '../data/cv.json';
---

<Layout title="About Me" description={`About ${cvData.name} - ${cvData.title}`}>
  <!-- Header -->
  <div class="relative overflow-hidden bg-[#060914] text-white py-16">
    <div class="pointer-events-none absolute inset-0 opacity-35" style="background-image: linear-gradient(rgba(0, 255, 200, 0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 255, 200, 0.08) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(0,255,240,0.22),transparent_45%),radial-gradient(circle_at_80%_10%,rgba(255,80,140,0.16),transparent_40%),radial-gradient(circle_at_60%_80%,rgba(86,140,255,0.2),transparent_50%)]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-3">
        <div class="h-1 w-8 bg-brand-red rounded-full"></div>
        <span class="text-white text-sm font-medium uppercase tracking-wider">About</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">About Me</h1>
      <p class="text-white text-lg max-w-3xl">
        My professional profile, delivery experience, certifications, and technical strengths.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
    <section class="bg-white dark:bg-brand-darkcard border border-gray-200 dark:border-gray-700 rounded-2xl p-6 sm:p-8">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
        <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-5">
          <picture>
            <source srcset="/images/Dominik_Modrzejewski_CV.avif" type="image/avif" />
            <source srcset="/images/Dominik_Modrzejewski_CV.webp" type="image/webp" />
            <img
              src="/images/Dominik_Modrzejewski_CV.jpg"
              alt="Portrait of Dominik Modrzejewski"
              class="h-24 w-24 sm:h-32 sm:w-32 rounded-xl object-cover border border-gray-200 dark:border-gray-700 shadow-sm"
              loading="eager"
              decoding="async"
              width="128"
              height="128"
            />
          </picture>
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-2">{cvData.name}</h2>
            <p class="text-lg text-blue-600 dark:text-blue-400 font-medium">{cvData.title}</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          {cvData.linkedin && (
            <a href={cvData.linkedin} target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-2 bg-blue-600 text-white hover:bg-brand-red px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          )}
          {'trailhead' in cvData && cvData.trailhead && (
            <a href={cvData.trailhead} target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-2 bg-blue-600 text-white hover:bg-brand-red px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow-sm">
              <span
                aria-hidden="true"
                style="mask-size: var(--trailhead-icon-scale); -webkit-mask-size: var(--trailhead-icon-scale);"
                class="block h-4 w-4 bg-current [mask-image:url('/images/trailhead-icon.svg')] [mask-repeat:no-repeat] [mask-position:center] [-webkit-mask-image:url('/images/trailhead-icon.svg')] [-webkit-mask-repeat:no-repeat] [-webkit-mask-position:center]"
              ></span>
              Trailhead
            </a>
          )}
          {cvData.github && (
            <a href={cvData.github} target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-2 bg-blue-600 text-white hover:bg-brand-red px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          )}
        </div>
      </div>
    </section>

    <!-- Summary -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white border-l-4 border-brand-red pl-4 mb-6">
        Professional Summary
      </h2>
      <p class="text-gray-600 dark:text-gray-300 leading-relaxed text-lg">{cvData.summary}</p>
    </section>

    <!-- Experience -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white border-l-4 border-brand-red pl-4 mb-6">
        Experience
      </h2>
      <div class="space-y-8">
        {cvData.experience.map((exp) => (
          <div class="relative pl-6 border-l-2 border-gray-200 dark:border-gray-700">
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-brand-red border-2 border-white dark:border-brand-darkbg"></div>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
              <h3 class="text-lg font-bold text-gray-900 dark:text-white">{exp.title}</h3>
              <span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">
                {exp.startDate} — {exp.current ? 'Present' : exp.endDate}
              </span>
            </div>
            <div class="flex items-center gap-2 mb-3">
              <span class="font-semibold text-blue-600 dark:text-blue-400">{exp.company}</span>
              <span class="text-gray-400">•</span>
              <span class="text-gray-500 dark:text-gray-400 text-sm">{exp.location}</span>
            </div>
            <p class="text-gray-600 dark:text-gray-300 mb-3">{exp.description}</p>
            <ul class="space-y-1.5">
              {exp.highlights.map((h) => (
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-600 dark:text-blue-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white border-l-4 border-brand-red pl-4 mb-6">
        Skills
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {Object.entries(cvData.skills).map(([category, skills]) => (
          <div class="bg-gray-50 dark:bg-brand-darkcard rounded-xl p-5 border border-gray-200 dark:border-gray-700">
            <h3 class="text-sm font-bold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-3 capitalize">
              {category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {(skills as string[]).map((skill) => (
                <span class="text-xs bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-600 px-3 py-1 rounded-full">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Certifications -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white border-l-4 border-brand-red pl-4 mb-6">
        Certifications
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {cvData.certifications.map((cert) => (
          <div class="flex items-center gap-3 bg-white dark:bg-brand-darkcard border border-gray-200 dark:border-gray-700 rounded-lg p-4">
            <div class="w-10 h-10 bg-brand-navy/10 dark:bg-blue-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900 dark:text-white">{cert.name}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">{cert.year}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white border-l-4 border-brand-red pl-4 mb-6">
        Education
      </h2>
      {cvData.education.map((edu) => (
        <div class="bg-white dark:bg-brand-darkcard border border-gray-200 dark:border-gray-700 rounded-xl p-6">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-gray-900 dark:text-white">{edu.degree}</h3>
              <p class="text-blue-600 dark:text-blue-400 font-medium">{edu.institution}</p>
            </div>
            <span class="text-sm text-gray-500 dark:text-gray-400">{edu.year}</span>
          </div>
        </div>
      ))}
    </section>

  </div>
</Layout>
